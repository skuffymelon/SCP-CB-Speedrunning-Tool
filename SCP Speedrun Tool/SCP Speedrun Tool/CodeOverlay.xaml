<Window x:Class="SCP_Speedrun_Tool.CodeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SCP_Speedrun_Tool"
        mc:Ignorable="d"
        FontFamily="Courier New"
        Title="CodeOverlay" Height="92" Width="135" Topmost="True" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Grid x:Name="main" Opacity="0.3">
        <Label PreviewMouseLeftButtonDown="MoveWindow"/>
        <Border IsHitTestVisible="False" BorderBrush="White" BorderThickness="1" CornerRadius="6" Background="Black" Opacity="0.3"/>

        <Grid x:Name="maynard" Height="92" VerticalAlignment="Top">
            <TextBlock IsHitTestVisible="False" Foreground="White" Text="CODE CONVERSION" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0"/>

            <TextBox x:Name="maycode" FontFamily="./Assets/#DS-Digital" Padding="0" MaxLength="4" FontSize="23" HorizontalContentAlignment="Center" Opacity="0.5" Margin="10,23,10,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="maytool" IsHitTestVisible="False" Opacity="0.4" Margin="10,30,10,0" Height="16" VerticalAlignment="Top" Text="MAYNARD" TextAlignment="Center" HorizontalAlignment="Center"/>

            <TextBox x:Name="maincode" FontFamily="./Assets/#DS-Digital" Padding="0" MaxLength="4" FontSize="23" HorizontalContentAlignment="Center" Opacity="0.5" Margin="10,57,10,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="maintool" IsHitTestVisible="False" Opacity="0.4" Margin="10,64,10,0" Height="16" VerticalAlignment="Top" Text="MAINTENENCE" TextAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
