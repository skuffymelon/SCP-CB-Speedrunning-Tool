<Window x:Class="SCP_Speedrun_Tool.Info"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SCP_Speedrun_Tool"
        mc:Ignorable="d"
        Title="Info" Height="450" Width="300" ResizeMode="NoResize" FontFamily="Courier New">
    <Window.Resources>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="Button.Static.Background" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="Button.Static.Border" Color="#FF707070"/>
        <SolidColorBrush x:Key="Button.MouseOver.Background" Color="#7FFDCCBE"/>
        <SolidColorBrush x:Key="Button.MouseOver.Border" Color="#FFB1623C"/>
        <SolidColorBrush x:Key="Button.Pressed.Background" Color="#BFF6C4C4"/>
        <SolidColorBrush x:Key="Button.Pressed.Border" Color="#FF8B3D2C"/>
        <SolidColorBrush x:Key="Button.Disabled.Background" Color="#FFF4F4F4"/>
        <SolidColorBrush x:Key="Button.Disabled.Border" Color="#FFADB2B5"/>
        <SolidColorBrush x:Key="Button.Disabled.Foreground" Color="#FF838383"/>
        <Style x:Key="RoundedBut" TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDefaulted" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.MouseOver.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.MouseOver.Border}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Pressed.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Pressed.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Disabled.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Disabled.Border}"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource Button.Disabled.Foreground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="TextBox.MouseOver.Border" Color="#FF7EB4EA"/>
        <SolidColorBrush x:Key="TextBox.Focus.Border" Color="#FF569DE5"/>
        <ControlTemplate x:Key="RoundedBox" TargetType="{x:Type TextBoxBase}">
            <Border x:Name="border" CornerRadius="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="false">
                    <Setter Property="Opacity" TargetName="border" Value="0.56"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.MouseOver.Border}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="true">
                    <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.Focus.Border}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="0,16,16,0" GlassFrameThickness="0,0,0,0" ResizeBorderThickness="5,5,5,5"></WindowChrome>
    </WindowChrome.WindowChrome>

    <Grid Background="Black">
        <Image Source="/logo2.png" VerticalAlignment="Top" Panel.ZIndex="-10000"/>

        <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <Grid>
                    <Image Source="/settings.png" Width="300" VerticalAlignment="Top"/>
                    <StackPanel Margin="0,110,0,0">
                        <Grid Height="329" Margin="5">
                            <Border Background="White" Opacity="0.2" CornerRadius="6"/>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="5">
                                <TextBlock Text="GENERAL SETTINGS" Foreground="White" TextAlignment="Center" FontSize="22"/>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="COPY GENERATED SEEDS" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox x:Name="gencopyseed" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="GENERATE SEED WITH CTRL+V" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox x:Name="gengenerate" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="COPY CALCULATED CODE" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox x:Name="gencmaynard" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <TextBlock Text="RANKED SETTINGS" Foreground="White" TextAlignment="Center" FontSize="22"/>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="RANKED MODE" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox x:Name="rankedmode" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <StackPanel x:Name="rdisable" VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="PRECACHE RANKED SEEDS" Foreground="White" FontSize="13" Margin="5"/>
                                    <CheckBox x:Name="rprecache" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <TextBlock Text="MAP GENERATION" Foreground="White" TextAlignment="Center" FontSize="22"/>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="LOCAL SEED GEN. (fast)" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox ToolTip="CHECK THIS IF YOU HAVE JAVA INSTALLED." x:Name="serverrun" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                                <TextBlock Text="SCP - CB MENU" Foreground="White" TextAlignment="Center" FontSize="22"/>
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" >
                                    <TextBlock Text="ENABLE CHEATS" Foreground="White" FontSize="15" Margin="5"/>
                                    <CheckBox x:Name="cheats" VerticalAlignment="Center" Margin="5" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="helpbut" Cursor="Hand" Style="{DynamicResource RoundedBut}" Content="HELP \/" FontSize="26" VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="#7FFFFFFF" Click="helpbut_Click" Margin="0,0,0,5"/>
                        </Grid>
                    </StackPanel>
                   
                </Grid>
                
                <Grid x:Name="HelpMenu" Visibility="Collapsed">
                    <Image Source="/help.png" VerticalAlignment="Top" Panel.ZIndex="-1" Height="200" Grid.RowSpan="2"/>
                    <StackPanel Margin="0,110,0,0" Grid.RowSpan="2">
                        <TextBlock Foreground="White" Width="150" Margin="10" TextWrapping="Wrap" FontSize="16" Text="SCP - CB MENU" TextAlignment="Center"/>

                        <TextBlock TextAlignment="Center" Foreground="White" Margin="5" Text="SHORTCUTS:" TextWrapping="Wrap" Width="290"/>

                        <TextBlock TextAlignment="Center" Foreground="White" Margin="5" Text="ALT + Q - ACHIEVEMENT TRAKCER&#10;ALT + T - CODE CONVERTER OVERLAY&#10;&#10;ALT + 1 - GODMODE&#10;ALT + 2 - NOCLIP&#10;ALT + 3 - INF. STAMINA&#10;ALT + 4 - NO TARGET&#10;&#10;ALT + E - 'E' COMMAND IN SPEEDRUN MOD&#10;ALT + G - GUARANTEED OMNI&#10;ALT + Z - 'SHOWMAP' COMMAND IN SPEEDRUN MOD&#10;&#10;ALT + V - OPEN MAP LAYOUT WINDOW WITH COPIED SEED" TextWrapping="Wrap" Width="290" Height="250"/>

                        <TextBlock Foreground="White" Width="150" Margin="10" TextWrapping="Wrap" FontSize="16" Text="CODE CONVERSION" TextAlignment="Center"/>
                        <Grid Height="293" Visibility="Visible">
                            <Grid x:Name="maynard" Width="135" Height="92" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,0,0,0">
                                <Label Panel.ZIndex="10"/>
                                <Border CornerRadius="4" Opacity="0.1">
                                    <Border.Background>
                                        <ImageBrush ImageSource="/menuwhite.jpg" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Foreground="White" Text="CODE CONVERSION" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0"/>

                                <TextBox Template="{DynamicResource RoundedBox}" x:Name="maycode" Padding="0" MaxLength="4" FontSize="20" HorizontalContentAlignment="Center" Opacity="0.5" Margin="10,23,10,0" VerticalAlignment="Top"/>
                                <TextBlock x:Name="maytool" IsHitTestVisible="False" Opacity="0.4" Margin="10,30,10,0" Height="16" VerticalAlignment="Top" Text="MAYNARD" TextAlignment="Center" HorizontalAlignment="Center"/>

                                <TextBox Template="{DynamicResource RoundedBox}" x:Name="maincode" Padding="0" MaxLength="4" FontSize="20" HorizontalContentAlignment="Center" Opacity="0.5" Margin="10,57,10,0" VerticalAlignment="Top"/>
                                <TextBlock x:Name="maintool" IsHitTestVisible="False" Opacity="0.4" Margin="10,64,10,0" Height="16" VerticalAlignment="Top" Text="MAINTENENCE" TextAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Foreground="White" Width="150" TextWrapping="Wrap" Text="--> MAYNARD&#10;&#10;PUT THE CODE FROM THE MAYNARD PAPER TO GET THE CODE FOR THE MAINTENENCE DOOR." Margin="150,28,0,-28"/>
                            <TextBlock Foreground="White" Width="150" TextWrapping="Wrap" TextAlignment="Center" Text="|&#10;|&#10;\/&#10;MAINTENENCE&#10;&#10;PUT THE CODE FROM 372's PAPER (maintenence door code) TO GET THE CODE FOR THE MAYNARD DOOR." Margin="0,92,150,-92"/>
                        </Grid>

                        <TextBlock Foreground="White" Width="150" Margin="10" TextWrapping="Wrap" FontSize="16" Text="MAP PREVIEW" TextAlignment="Center"/>
                        <TextBlock Foreground="White" Text="THIS SECTION WILL EXPLAIN HOW TO USE AND READ THE MAP PREVIEWER.&#10;&#10;THERE ARE 5 ROOM SHAPES:" TextWrapping="Wrap" Width="280" TextAlignment="Center"/>
                        <Grid>
                            <Border Background="White" Height="190" CornerRadius="10" Opacity="0.2" Margin="5"/>
                            <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ROOM SHAPES:" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="21" Height="21" Source="roomd/room2.png" ToolTip="room2" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- ROOM WITH 2 CORRIDORS" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="21" Height="21" Source="roomd/room2c.png" ToolTip="room2c" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- ROOM WITH 2 CORRIDORS&#10;(DIAGONAL)" TextAlignment="Center" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="21" Height="21" Source="roomd/room3.png" ToolTip="room3" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- ROOM WITH 3 CORRIDORS" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="21" Height="21" Source="roomd/room4.png" ToolTip="room4" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- ROOM WITH 4 CORRIDORS" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="21" Height="21" Source="roomd/room1.png" ToolTip="room1" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- ROOM WITH 1 CORRIDOR" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <TextBlock Foreground="White" Margin="5" Text="THE FACILITY HAS 3 ZONES, YOU START IN THE LIGHT CONTAINMENT ZONE AND YOU HAVE TO PROGRESS YOUR WAY TOWARDS HEAVY AND ENTRANCE." TextWrapping="Wrap" Width="280" TextAlignment="Center"/>
                        <Grid>
                            <Border Background="White" Height="240" CornerRadius="10" Opacity="0.2" Margin="5"/>
                            <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ZONES:" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="6" Width="32" Height="32" Background="Lime" Opacity="0.25" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="-          ENTRANCE ZONE" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="6" Width="32" Height="32" Background="Green" Opacity="0.25" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="-             TRANSITION" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="6" Width="32" Height="32" Background="Red" Opacity="0.25" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- HEAVY CONTAINMENT ZONE" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="6" Width="32" Height="32" Background="Orange" Opacity="0.25" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="-             TRANSITION" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border CornerRadius="6" Width="32" Height="32" Background="Yellow" Opacity="0.25" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Text="- LIGHT CONTAINMENT ZONE" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <TextBlock Width="280" TextAlignment="Center" Margin="5" TextWrapping="Wrap" Foreground="White" Text="THIS SECTION WILL LIST THE MOST IMPORTANT ROOMS AND ITEMS YOU MAY GET IN THEM."/>
                        <Grid>
                            <Border Background="#FFE7F752" CornerRadius="10" Opacity="0.2" Margin="5"/>
                            <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Foreground="White" Text="LIGHT CONTAINMENT ZONE:" Margin="0,10" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="White" Text="THE MOST IMPORTANT ROOMS IN LIGHT CONTAINMENT ARE:" Width="280" TextWrapping="Wrap" TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room2.png"/>
                                        <Image Source="roomd/closet.png"/>
                                        <TextBlock Foreground="White" Text="K1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-38,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM2CLOSETS" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="LEVEL 1 KEYCARD AND GASMASK" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room2.png"/>
                                        <Image Source="roomd/1t.png"/>
                                        <TextBlock Foreground="White" Text="K2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-38,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM2TESTROOM2" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="LEVEL 2 KEYCARD AND S-NAV" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="914" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- 914" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="KEYCARD OMNI or LEVEL 3, ULTIMATE S-NAV, SUPER GASMASK, SMALL MEDKIT or STRANGE BOTTLE" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room2.png"/>
                                        <Image Source="roomd/1t.png"/>
                                        <TextBlock Foreground="White" Text="CAM" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM2SL" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="UNLOCKS PATHWAY TO HEAVY CONTAINMENT ZONE." Margin="0,0,0,10" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Border Background="#FFFD0000" CornerRadius="10" Opacity="0.2" Margin="5"/>
                            <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Foreground="White" Text="HEAVY CONTAINMENT ZONE:" Margin="0,10" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="White" Text="IMPORTANT ROOMS IN HEAVY CONTAINMENT ARE:" Width="280" TextWrapping="Wrap" TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room2.png"/>
                                        <Image Source="roomd/b2d.png"/>
                                        <TextBlock Foreground="White" Text="049" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM049" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="FOR INTENDED% - KEYCARD LEVEL 4" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="106" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM106" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="KEYCARD LEVEL 5 AND SECONDARY GATE A ENDING" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="008" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- 008" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="ENABLES ACCESS TO ENTERANCE ZONE" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="079" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM079" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="UNLOCKS ABILITY TO BEAT THE GAME." Margin="0,0,0,10" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>

                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Border Background="#FF00FD1B" CornerRadius="10" Opacity="0.2" Margin="5"/>
                            <StackPanel Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Foreground="White" Text="ENTRANCE ZONE:" Margin="0,10" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="White" Text="IMPORTANT ROOMS IN THE ENTRANCE ZONE ARE:" Width="280" TextWrapping="Wrap" TextAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room2c.png"/>
                                        <TextBlock Foreground="White" Text="EC" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- ROOM2CCONT" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="MANDATORY ROOM FOR BEATING THE GAME, HAS THE REMOTE DOOR CONTROL LEVER, WHICH IS USED TO BEAT THE GAME." Width="260" TextAlignment="Center" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- GATEAENTRANCE" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="GATE A ENTRANCE - EXIT FOR GATE A ENDING" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Width="21" Height="21" Margin="0,5,5,5">
                                        <Image Source="roomd/room1.png"/>
                                        <TextBlock Foreground="White" Text="B" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,-45,0"/>
                                    </Grid>
                                    <TextBlock Text="- EXIT1" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="22,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="GATE B ENTRANCE - EXIT FOR GATE B ENDING" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="A USEFUL TIP: GATE EXITS ALWAYS SPAWN ON TOP AND THE FAR LEFT SIDE OF THE MAP, AND THE ELECTRICAL ROOM (EC) PRIMARILY SPAWNS ON THE RIGHT SIDE OF ENTRANCE ZONE" Margin="0,10" TextAlignment="Center" Width="260" TextWrapping="Wrap" Foreground="White" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        
                    </StackPanel>
                </Grid>

                <Grid>
                    <Image Source="/scpctransf.png" VerticalAlignment="Top" Panel.ZIndex="-1" Height="200"/>
                    <StackPanel Margin="0,105,0,0">
