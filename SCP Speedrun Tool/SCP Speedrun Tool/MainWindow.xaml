<Window x:Class="SCP_Speedrun_Tool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SCP_Speedrun_Tool"
        mc:Ignorable="d"
        Title="SCP Speedrun Tool" Height="450" Width="300" ResizeMode="NoResize"
        FontFamily="Courier New"
        Icon="/scpticon1.png">
    <Window.Resources>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="Button.Static.Background" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="Button.Static.Border" Color="#FF707070"/>
        <SolidColorBrush x:Key="Button.MouseOver.Background" Color="#11BEE6FD"/>
        <SolidColorBrush x:Key="Button.MouseOver.Border" Color="#FFE26767"/>
        <SolidColorBrush x:Key="Button.Pressed.Background" Color="#33C4E5F6"/>
        <SolidColorBrush x:Key="Button.Pressed.Border" Color="#FFF51212"/>
        <SolidColorBrush x:Key="Button.Disabled.Background" Color="#00F4F4F4"/>
        <SolidColorBrush x:Key="Button.Disabled.Border" Color="#3FFF0000"/>
        <SolidColorBrush x:Key="Button.Disabled.Foreground" Color="#FF838383"/>
        <Style x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDefaulted" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.MouseOver.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.MouseOver.Border}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Pressed.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Pressed.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Disabled.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Disabled.Border}"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource Button.Disabled.Foreground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="TextBox.Static.Border" Color="#FFABAdB3"/>
        <SolidColorBrush x:Key="TextBox.MouseOver.Border" Color="#FF7EB4EA"/>
        <SolidColorBrush x:Key="TextBox.Focus.Border" Color="#FF569DE5"/>
        <Style x:Key="RoundedBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{StaticResource TextBox.Static.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="KeyboardNavigation.TabNavigation" Value="None"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="AllowDrop" Value="true"/>
            <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border" CornerRadius="3" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" TargetName="border" Value="0.56"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.MouseOver.Border}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TextBox.Focus.Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsInactiveSelectionHighlightEnabled" Value="true"/>
                        <Condition Property="IsSelectionActive" Value="false"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="SelectionBrush" Value="{DynamicResource {x:Static SystemColors.InactiveSelectionHighlightBrushKey}}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="16,16,16,16" GlassFrameThickness="0,0,0,0" ResizeBorderThickness="5,5,5,5"></WindowChrome>
    </WindowChrome.WindowChrome>

    <Grid Background="Black">
        <Grid x:Name="TaskBar" Height="54" Width="300" Panel.ZIndex="10000" VerticalAlignment="Top">
            <Label MouseDown="MoveWindow"/>
            <Button Click="CloseProgram" Cursor="Hand" Padding="0,1,0,0" BorderThickness="1" Foreground="White" Content="X" FontFamily="Courier New" Background="Transparent" Style="{DynamicResource RoundedButton}" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0"/>
            <Button Click="Minimize" Cursor="Hand" Padding="0,1,0,0" BorderThickness="1" Foreground="White" Content="-" FontFamily="Courier New" Background="Transparent" Style="{DynamicResource RoundedButton}" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,35,0"/>
            <Button x:Name="infobutton" Padding="-1,-1,0,0" Click="InfoButton" Cursor="Hand" BorderThickness="1" Foreground="White" FontFamily="Courier New" Background="Transparent" Style="{DynamicResource RoundedButton}" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,59,0">
                <Image Source="/Info2.png" Width="16" Height="16"></Image>
            </Button>
        </Grid>

        <Image Source="/TEST4.png" VerticalAlignment="Top" Panel.ZIndex="-10000"/>
        <Image x:Name="chirmasterr" Opacity="0" Source="/Assets/chirmas.png" VerticalAlignment="Bottom" Panel.ZIndex="-10000" Height="100" HorizontalAlignment="Left"/>

        <Grid x:Name="scpcbmenu" Margin="10,199,155,0" Height="94" VerticalAlignment="Top">
            <Border CornerRadius="4" Opacity="0.1">
                <Border.Background>
                    <ImageBrush ImageSource="/menuwhite.jpg" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <TextBlock Foreground="White" Text="SCP - CB MENU" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0"/>

            <Button x:Name="scpmenuopen" Click="UpdateProcesses" Content="OPEN MENU" FontSize="11" Style="{DynamicResource RoundedButton}" Padding="4,2,4,2" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Top" BorderBrush="Red" Margin="5,25,5,5" HorizontalAlignment="Center" Width="125"/>

            <TextBlock Foreground="White" Text="QUICK SETTINGS" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0"/>

            <Button Click="QuiqChange" Uid="ach" Content="ACHIEVEMENT" FontSize="11" Style="{DynamicResource RoundedButton}" Padding="4,2,4,2" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Top" BorderBrush="#FFC3AFAF" Margin="5,70,5,5" HorizontalAlignment="Left"/>
            <Button Click="QuiqChange" Uid="code" Content="CODE" FontSize="11" Style="{DynamicResource RoundedButton}" Padding="4,2,4,2" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Top" BorderBrush="#FFC3AFAF" Margin="5,70,5,5" HorizontalAlignment="Right"/>
        </Grid>


        <Grid x:Name="maynard" Margin="10,97,155,0" Height="92" VerticalAlignment="Top">
            <Border CornerRadius="4" Opacity="0.1">
                <Border.Background>
                    <ImageBrush ImageSource="/menuwhite.jpg" Stretch="UniformToFill"/>
                </Border.Background>
            </Border>
            <TextBlock Foreground="White" Text="CODE CONVERSION" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0"/>

            <TextBox x:Name="maycode" FontFamily="./Assets/#DS-Digital" Padding="0" MaxLength="4" FontSize="23" HorizontalContentAlignment="Center" Style="{DynamicResource RoundedBox}" Opacity="0.5" Margin="10,23,10,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="maytool" IsHitTestVisible="False" Opacity="0.4" Margin="10,30,10,0" Height="16" VerticalAlignment="Top" Text="MAYNARD" TextAlignment="Center" HorizontalAlignment="Center"/>

            <TextBox x:Name="maincode" FontFamily="./Assets/#DS-Digital" Padding="0" MaxLength="4" FontSize="23" HorizontalContentAlignment="Center" Style="{DynamicResource RoundedBox}" Opacity="0.5" Margin="10,57,10,0" VerticalAlignment="Top"/>
            <TextBlock x:Name="maintool" IsHitTestVisible="False" Opacity="0.4" Margin="10,64,10,0" Height="16" VerticalAlignment="Top" Text="MAINTENENCE" TextAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <Grid x:Name="maplayout" HorizontalAlignment="Right" VerticalAlignment="Top" Width="135" Height="65" Margin="10,97,10,0">
            <Border CornerRadius="4" Opacity="0.1">
                <Border.Background>
                    <ImageBrush ImageSource="/menuwhite.jpg"/>
                </Border.Background>
            </Border>
            <TextBlock Text="MAP LAYOUT" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" Margin="0,4,0,0"/>
            <TextBox Opacity="0.5" x:Name="seed" FontSize="12" MaxLength="15" Style="{DynamicResource RoundedBox}" Text="" Margin="0,20,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" Width="114" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></TextBox>
            <TextBlock x:Name="seedtool" IsHitTestVisible="False" Opacity="0.4" Margin="0,22,0,0" Height="16" VerticalAlignment="Top" Text="SEED (ctrl+v)" TextAlignment="Center" HorizontalAlignment="Center"/>
            <Button Click="SeedLoad" ClickMode="Press" Style="{DynamicResource RoundedButton}" Cursor="Hand" Foreground="White" Background="Transparent" Content="LOAD MAP" Padding="2,1,2,1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,42,0,0" BorderBrush="#FFC81818"/>

        </Grid>

        <Grid x:Name="rankedseed" HorizontalAlignment="Right" VerticalAlignment="Top" Width="135" Height="100" Margin="10,172,10,0">
            <Border CornerRadius="4" Opacity="0.1">
                <Border.Background>
                    <ImageBrush ImageSource="/menuwhite.jpg"/>
                </Border.Background>
            </Border>
            <TextBlock Text="RANKED SPEEDRUNING" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" Margin="0,6,0,0"/>
            <TextBox x:Name="rankseed" MaxLines="1" MaxLength="6" Style="{DynamicResource RoundedBox}" IsEnabled="False" VerticalAlignment="Center" FontSize="18" Padding="2" HorizontalAlignment="Center" Text="" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="75" Height="27" Margin="0,-29,0,0"/>
            <TextBlock x:Name="ranktool" IsHitTestVisible="False" FontSize="10" Opacity="0.4" Height="16" VerticalAlignment="Center" Text="RANKED SEED" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,22"/>
            <Button Click="SendRanked" Content="SUBMIT" FontSize="11" Style="{DynamicResource RoundedButton}" Padding="2" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Bottom" BorderBrush="#FF38C312" Margin="5,0,5,5" HorizontalAlignment="Right"/>
            <Button x:Name="rankedbut" Click="RankedGenerate" Content="GENERATE" FontSize="11" Style="{DynamicResource RoundedButton}" Padding="4,2,4,2" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Bottom" BorderBrush="#FF00FF4A" Margin="5,0,5,5" Width="72" HorizontalAlignment="Left"/>
            <Button x:Name="rankpreview" IsEnabled="False" Click="LoadLastRanked" Content="LOAD LAST SEED" FontSize="10" Style="{DynamicResource RoundedButton}" HorizontalContentAlignment="Center" Cursor="Hand" Background="Transparent" Foreground="White" VerticalAlignment="Bottom" BorderBrush="Red" Margin="0,0,0,28" HorizontalAlignment="Center"/>
        </Grid>

        <Grid x:Name="suggestions" VerticalAlignment="Bottom" Height="75" Opacity="0.5">
            <TextBlock Text="got any suggestions?" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,42"/>
            <Button Style="{DynamicResource RoundedButton}" Click="suggestionslink" Cursor="Hand" Foreground="White" Padding="2" Content="SUGGEST FEATURES" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#19DDDDDD"/>
        </Grid>
    </Grid>
</Window>
